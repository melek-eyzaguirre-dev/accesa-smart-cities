# ============================================
# CONFIGURACIÓN DE HEDERA TESTNET
# ============================================
# Copia este archivo a .env y completa con tus credenciales
# cp .env.example .env

# ID de tu cuenta en Hedera (formato: 0.0.XXXXXX)
HEDERA_ACCOUNT_ID=0.0.TU_NUMERO_AQUI

# Clave privada de tu cuenta (comienza con 302e...)
HEDERA_PRIVATE_KEY=302e020100300506032b65700422042_TU_CLAVE_AQUI

# Red de Hedera (testnet para desarrollo, mainnet para producción)
HEDERA_NETWORK=testnet

# ============================================
# CONFIGURACIÓN DE TOKENS ACCESA
# ============================================
# ID del token ACCESA una vez creado (se llena automáticamente)
ACCESA_TOKEN_ID=

# ============================================
# CONFIGURACIÓN DE AGENTES DE IA (OPCIONAL)
# ============================================
# API Key de OpenAI (para agentes con IA avanzada)
OPENAI_API_KEY=

# API Key de Anthropic (alternativa)
ANTHROPIC_API_KEY=

# ============================================
# CONFIGURACIÓN DE LA API
# ============================================
FLASK_PORT=5000
FLASK_DEBUG=True
