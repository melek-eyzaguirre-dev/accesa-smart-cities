# ============================================
# CONFIGURACIÓN DE HEDERA TESTNET
# ============================================
# Estas son las credenciales para conectarte a la red de pruebas de Hedera
# NUNCA compartas estas claves en producción

# ID de tu cuenta en Hedera (formato: 0.0.XXXXXX)
HEDERA_ACCOUNT_ID=0.0.1234567

# Clave privada de tu cuenta (comienza con 302e...)
HEDERA_PRIVATE_KEY=302e020100300506032b65700422042...

# Red de Hedera (testnet para desarrollo, mainnet para producción)
HEDERA_NETWORK=testnet

# ============================================
# CONFIGURACIÓN DE TOKENS ACCESA
# ============================================
# ID del token ACCESA una vez creado
ACCESA_TOKEN_ID=

# ============================================
# CONFIGURACIÓN DE AGENTES DE IA
# ============================================
# API Key de OpenAI (opcional, para agentes más inteligentes)
OPENAI_API_KEY=

# API Key de Anthropic (opcional)
ANTHROPIC_API_KEY=

# ============================================
# CONFIGURACIÓN DE LA API
# ============================================
FLASK_PORT=5000
FLASK_DEBUG=True

# ============================================
# CÓMO OBTENER TUS CREDENCIALES DE HEDERA
# ============================================
# 1. Ve a https://portal.hedera.com/
# 2. Crea una cuenta gratuita
# 3. Crea un nuevo proyecto en Testnet
# 4. Copia tu Account ID y Private Key
# 5. Pega los valores arriba
# 6. Guarda fondos de prueba desde: https://portal.hedera.com/faucet